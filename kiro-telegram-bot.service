[Unit]
Description=Kiro Headless Telegram Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/kiro-headless-telegram-bot
ExecStart=/usr/bin/node src/index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
EnvironmentFile=/home/ubuntu/kiro-headless-telegram-bot/.env

[Install]
WantedBy=multi-user.target
