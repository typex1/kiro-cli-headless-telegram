# ============================================
# Kiro Headless Bot — Configuration
# ============================================
# Configure Telegram, Signal, or both channels.

# REQUIRED: Kiro API Key for headless mode
# Generate at https://app.kiro.dev (requires Pro/Pro+/Power subscription)
KIRO_API_KEY=your-kiro-api-key-here

# Path to kiro-cli binary (default: kiro-cli from PATH)
# KIRO_CLI_PATH=/usr/local/bin/kiro-cli

# Workspace directory for Kiro to operate in
# KIRO_WORKSPACE=/path/to/your/project

# Timeout for kiro-cli commands in ms (default: 120000)
# KIRO_TIMEOUT=120000

# Optional: Groq API key for voice message transcription (works for both channels)
# GROQ_API_KEY=your-groq-api-key-here

# ============================================
# TELEGRAM (optional — remove or leave empty to disable)
# ============================================

# Telegram Bot Token from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated Telegram user IDs allowed to use the bot
# Get your ID from @userinfobot on Telegram
# ALLOWED_USERS=123456789

# ============================================
# SIGNAL (optional — remove or leave empty to disable)
# ============================================

# Your registered Signal phone number (e.g. +491234567890)
# signal-cli must be installed and registered with this number
SIGNAL_ACCOUNT=+491234567890

# Path to signal-cli binary (default: signal-cli from PATH)
# SIGNAL_CLI_PATH=/usr/local/bin/signal-cli

# Comma-separated phone numbers allowed to use the Signal bot
# Leave empty to allow anyone
# SIGNAL_ALLOWED_USERS=+491234567890,+441234567890
