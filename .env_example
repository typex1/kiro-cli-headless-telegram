# ============================================
# Kiro Headless Telegram Bot — Configuration
# ============================================

# REQUIRED: Telegram Bot Token
# Get from @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# REQUIRED: Kiro API Key for headless mode
# Generate at https://app.kiro.dev (requires Pro/Pro+/Power subscription)
KIRO_API_KEY=your-kiro-api-key-here

# Path to kiro-cli binary (default: kiro-cli from PATH)
# KIRO_CLI_PATH=/usr/local/bin/kiro-cli

# Workspace directory for Kiro to operate in
# KIRO_WORKSPACE=/path/to/your/project

# Comma-separated Telegram user IDs allowed to use the bot
# Get your ID from @userinfobot on Telegram
# ALLOWED_USERS=123456789

# Timeout for kiro-cli commands in ms (default: 120000)
# KIRO_TIMEOUT=120000

# Optional: Groq API key for voice message transcription
# GROQ_API_KEY=your-groq-api-key-here
